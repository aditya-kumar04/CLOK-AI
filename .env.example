# CLOK AI Environment Variables

# Groq API Key (Free)
# Get your free API key from: https://console.groq.com/
# 1. Sign up/login to Groq
# 2. Go to API Keys section
# 3. Create a new key
# 4. Copy the key below (remove the # and replace YOUR_KEY_HERE)

VITE_GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# Google Gemini API Key (Free)
# Get your free API key from: https://aistudio.google.com/app/apikey
# 1. Go to Google AI Studio
# 2. Create a new API key
# 3. Copy the key below

VITE_GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Alternative: You can also use other free APIs
# OpenAI (has free tier limits)
# VITE_OPENAI_API_KEY=YOUR_KEY_HERE

# Hugging Face (free models)
# VITE_HUGGINGFACE_API_KEY=YOUR_KEY_HERE
